# Copy this file to .env and adjust if needed.
# .env is gitignored — never commit real credentials.

PIXLERPAY_LOGIN_URL=https://pixlerpay.com/auth/merchant-login

# Optional: set to "true" to watch the browser while it runs (useful for
# first-time setup / debugging selectors). Set to "false" for silent runs.
PIXLERPAY_HEADFUL=true

# Where downloaded payout reports should be saved
DOWNLOAD_DIR=./data

# How many days back to pull the report for (today included).
# e.g. REPORT_DAYS=7 -> last 7 days. Defaults to 30 if not set.
REPORT_DAYS=30

# Alternative: set explicit dates instead of REPORT_DAYS (YYYY-MM-DD).
# If both DATE_FROM and DATE_TO are set, they override REPORT_DAYS.
# DATE_FROM=2026-07-01
# DATE_TO=2026-07-09

# --- Google Drive sync (see README.md "Google Drive sync" for setup) ---
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./data/gdrive-service-account.json
GOOGLE_DRIVE_FOLDER_ID=paste_the_target_drive_folder_id_here

# NOTE: per-client login credentials no longer live here.
# See data/accounts.example.json -> copy to data/accounts.json and fill in
# each merchant login's real username/password (also gitignored).

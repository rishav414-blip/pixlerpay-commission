# Copy this file to .env and adjust if needed.
# .env is gitignored — never commit real credentials.

PIXLERPAY_LOGIN_URL=https://pixlerpay.com/auth/merchant-login

# Optional: set to "true" to watch the browser while it runs (useful for
# first-time setup / debugging selectors). Set to "false" for silent runs.
PIXLERPAY_HEADFUL=true

# Where downloaded payout reports should be saved
DOWNLOAD_DIR=./data

# How many days back to pull the report for (today included).
# e.g. REPORT_DAYS=7 -> last 7 days. Defaults to 30 if not set.
REPORT_DAYS=30

# Alternative: set explicit dates instead of REPORT_DAYS (YYYY-MM-DD).
# If both DATE_FROM and DATE_TO are set, they override REPORT_DAYS.
# DATE_FROM=2026-07-01
# DATE_TO=2026-07-09

# --- Google Drive sync (see README.md "Google Drive sync" for setup) ---
GOOGLE_DRIVE_FOLDER_ID=paste_the_target_drive_folder_id_here
GOOGLE_DRIVE_RESULTS_FILE_ID=paste_the_commission-results.json_file_id_here
GOOGLE_DRIVE_PAYNIX_FILE_ID=paste_the_paynix-results.json_file_id_here
GOOGLE_DRIVE_API_KEY=paste_a_drive-api-restricted_read-only_key_here

# NOTE: per-client login credentials no longer live here.
# See data/accounts.example.json -> copy to data/accounts.json and fill in
# each merchant login's real username/password (also gitignored).

# --- Paynix reseller portal ---
PAYNIX_LOGIN_URL=https://reseller.paynix.co.in/auth/login
PAYNIX_USERNAME=your_paynix_username_here
PAYNIX_PASSWORD=your_paynix_password_here
PAYNIX_HEADFUL=true

# --- PixlerPay's own Paynix merchant account (separate from the 12 reseller merchants) ---
PIXLERPAY_MERCHANT_LOGIN_URL=https://merchant.paynix.co.in/auth/login
PIXLERPAY_MERCHANT_USERNAME=your_pixlerpay_merchant_email_here
PIXLERPAY_MERCHANT_PASSWORD=your_pixlerpay_merchant_password_here
GOOGLE_DRIVE_PIXLERPAY_MERCHANT_FILE_ID=paste_the_pixlerpay-merchant-results.json_file_id_here

# --- Telegram alerts (see README.md "Telegram alerts" for setup) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
